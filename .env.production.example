# Frontend production environment.
#
# Use "/api" when the web container and API share the same domain through Nginx.
# If the frontend is deployed on Netlify and the API is hosted elsewhere, use a full API URL:
# VITE_API_BASE_URL=https://lowcode-api.example.com/api
VITE_API_BASE_URL=/api

# Comma-separated origin allowlist for low-code HTTP actions.
# Keep this explicit in production. Example:
# VITE_LOWCODE_HTTP_ALLOWED_ORIGINS=https://api.example.com,https://crm.example.com
VITE_LOWCODE_HTTP_ALLOWED_ORIGINS=https://api.example.com
