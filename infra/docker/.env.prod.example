# Copy this file to infra/docker/.env before running:
# docker compose --env-file infra/docker/.env -f infra/docker/docker-compose.prod.example.yml up -d --build

POSTGRES_USER=lowcode_app
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_DB=lowcode_editor

# Server runtime env.
JWT_SECRET=replace-this-with-a-random-secret-of-at-least-32-characters
JWT_EXPIRES_IN=7d
FRONTEND_ORIGIN=https://lowcode.example.com
UPLOAD_DIR=/app/server/uploads
UPLOAD_MAX_SIZE=5242880

# Expose the web container. In real production this is often 80 behind a host firewall or 127.0.0.1 behind another proxy.
WEB_PORT=8080

# Frontend build args.
VITE_API_BASE_URL=/api
VITE_LOWCODE_HTTP_ALLOWED_ORIGINS=https://api.example.com
