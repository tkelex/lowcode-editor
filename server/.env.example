DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lowcode_editor?schema=public"
JWT_SECRET="replace-with-a-random-secret"
JWT_EXPIRES_IN="7d"
PORT="3000"
FRONTEND_ORIGIN="http://localhost:5173"
UPLOAD_DIR="./uploads"
UPLOAD_MAX_SIZE="5242880"
NODE_ENV="development"

# Optional AI page builder provider. When AI_PROVIDER_API_KEY is empty, the
# server returns a deterministic editable draft instead of calling a model.
AI_PROVIDER_BASE_URL="https://api.openai.com/v1"
AI_PROVIDER_API_KEY=""
AI_PROVIDER_MODEL="gpt-4.1-mini"
AI_PROVIDER_TIMEOUT_MS="30000"
AI_AGENT_MAX_STEPS="8"
AI_AGENT_MAX_REPAIRS="1"
AI_AGENT_TIMEOUT_MS="45000"
AI_AGENT_MAX_CONTEXT_COMPONENTS="80"
AI_AGENT_RATE_LIMIT_PER_MINUTE="12"
