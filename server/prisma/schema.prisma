generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  username     String        @unique
  passwordHash String
  nickname     String?
  avatarUrl    String?
  projects     Project[]
  memberships  ProjectMember[]
  pages        Page[]        @relation("PageCreator")
  pageVersions PageVersion[] @relation("PageVersionCreator")
  pageTemplates PageTemplate[] @relation("PageTemplateCreator")
  assets       Asset[]       @relation("AssetUploader")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Project {
  id          Int      @id @default(autoincrement())
  ownerId     Int
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      String   @default("active")
  pages       Page[]
  members     ProjectMember[]
  templates   PageTemplate[]
  assets      Asset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
}

model ProjectMember {
  id        Int               @id @default(autoincrement())
  projectId Int
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    Int
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ProjectMemberRole @default(VIEWER)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId, role])
}

model Page {
  id                 Int           @id @default(autoincrement())
  projectId          Int
  project            Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById        Int
  createdBy          User          @relation("PageCreator", fields: [createdById], references: [id], onDelete: Cascade)
  name               String
  routePath          String
  schema             Json
  publicId           String?       @unique @default(cuid())
  isPublished        Boolean       @default(false)
  publishedAt        DateTime?
  publishedVersionId Int?
  versions           PageVersion[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([projectId])
  @@index([createdById])
  @@unique([projectId, routePath])
}

model PageVersion {
  id          Int      @id @default(autoincrement())
  pageId      Int
  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdById Int
  createdBy   User     @relation("PageVersionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  versionNo   Int
  schema      Json
  source      String   @default("save")
  message     String?
  createdAt   DateTime @default(now())

  @@index([pageId, createdAt])
  @@index([createdById])
  @@unique([pageId, versionNo])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int?
  projectId  Int?
  pageId     Int?
  action     String
  targetType String
  targetId   String?
  summary    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([pageId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model PageTemplate {
  id          Int      @id @default(autoincrement())
  projectId   Int?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById Int
  createdBy   User     @relation("PageTemplateCreator", fields: [createdById], references: [id], onDelete: Cascade)
  type        String   @default("block")
  title       String
  description String?
  category    String?
  tags        String[] @default([])
  schema      Json
  visibility  String   @default("project")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, type])
  @@index([createdById])
  @@index([visibility, type])
}

model Asset {
  id           Int      @id @default(autoincrement())
  projectId    Int
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedById Int
  uploadedBy   User     @relation("AssetUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  storageKey   String
  category     String   @default("file")
  createdAt    DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([uploadedById])
  @@index([category])
}

enum ProjectMemberRole {
  OWNER
  EDITOR
  VIEWER
}
