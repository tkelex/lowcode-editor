# Server production environment.
#
# Replace every example value before deploying. Do not commit real production secrets.

NODE_ENV=production
PORT=3000

# Use a dedicated database user with a strong password in production.
DATABASE_URL="postgresql://lowcode_app:replace-with-strong-db-password@postgres:5432/lowcode_editor?schema=public"

# Must be at least 32 random characters. Generate one with a password manager or:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-this-with-a-random-secret-of-at-least-32-characters"
JWT_EXPIRES_IN="7d"

# Must be the real frontend origin. Do not use localhost in production.
FRONTEND_ORIGIN="https://lowcode.example.com"

# Use a persistent volume or mounted directory.
UPLOAD_DIR="/app/server/uploads"
UPLOAD_MAX_SIZE="5242880"

# Optional AI page builder provider. Keep the key server-side only.
# Leave AI_PROVIDER_API_KEY empty to disable model calls and use fallback drafts.
AI_PROVIDER_BASE_URL="https://api.openai.com/v1"
AI_PROVIDER_API_KEY=""
AI_PROVIDER_MODEL="gpt-4.1-mini"
AI_PROVIDER_TIMEOUT_MS="30000"
AI_AGENT_MAX_STEPS="8"
AI_AGENT_MAX_REPAIRS="1"
AI_AGENT_TIMEOUT_MS="45000"
AI_AGENT_MAX_CONTEXT_COMPONENTS="80"
AI_AGENT_RATE_LIMIT_PER_MINUTE="12"
